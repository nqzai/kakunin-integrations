{
  "name": "@kakunin/middleware",
  "version": "0.2.0",
  "description": "Express, Fastify, and Next.js middleware for Kakunin AI agent certificate enforcement",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./express": {
      "types": "./dist/express.d.ts",
      "import": "./dist/express.mjs",
      "require": "./dist/express.js"
    },
    "./fastify": {
      "types": "./dist/fastify.d.ts",
      "import": "./dist/fastify.mjs",
      "require": "./dist/fastify.js"
    },
    "./next": {
      "types": "./dist/next.d.ts",
      "import": "./dist/next.mjs",
      "require": "./dist/next.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup --clean",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build && npm run typecheck"
  },
  "keywords": [
    "kakunin",
    "middleware",
    "ai-agents",
    "compliance",
    "x509",
    "express",
    "fastify",
    "nextjs",
    "gateway",
    "mica",
    "eu-ai-act"
  ],
  "license": "Apache-2.0",
  "homepage": "https://kakunin.ai/docs/enforcement",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nqzai/kakunin-integrations.git",
    "directory": "packages/middleware"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^4.1.10",
    "@types/node": "^20.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "bugs": {
    "url": "https://github.com/nqzai/kakunin-integrations/issues"
  }
}
