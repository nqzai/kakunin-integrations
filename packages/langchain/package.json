{
  "name": "@kakunin/langchain",
  "version": "0.2.2",
  "description": "Kakunin compliance tools for LangChain JS/TS — verify agent certificates and scopes inside tools and chains",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "keywords": [
    "kakunin",
    "langchain",
    "compliance",
    "ai-agents",
    "x509",
    "mica",
    "eu-ai-act"
  ],
  "license": "Apache-2.0",
  "homepage": "https://kakunin.ai",
  "dependencies": {
    "@kakunin/sdk": "^0.2.0"
  },
  "peerDependencies": {
    "@langchain/core": ">=0.1.0",
    "zod": ">=3.25 || ^4.0"
  },
  "devDependencies": {
    "@langchain/core": "^0.3.0",
    "@kakunin/sdk": "^0.2.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^4.1.10",
    "zod": "^4.4.3"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kakunin-ai/kakunin-integrations.git",
    "directory": "packages/langchain"
  },
  "bugs": {
    "url": "https://github.com/kakunin-ai/kakunin-integrations/issues"
  }
}
