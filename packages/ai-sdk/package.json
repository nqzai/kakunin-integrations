{
  "name": "@kakunin/ai-sdk",
  "version": "0.4.0",
  "description": "Kakunin compliance tools for the Vercel AI SDK — verify agent certificates, check scope, read risk scores, emit audit events",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "keywords": [
    "kakunin",
    "ai-sdk",
    "vercel",
    "compliance",
    "ai-agents",
    "x509",
    "mica",
    "eu-ai-act"
  ],
  "license": "Apache-2.0",
  "homepage": "https://kakunin.ai",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kakunin-ai/kakunin-integrations.git",
    "directory": "packages/ai-sdk"
  },
  "dependencies": {
    "@kakunin/sdk": "^0.2.0"
  },
  "peerDependencies": {
    "ai": ">=5.0.0",
    "zod": ">=3.25 || ^4.0"
  },
  "peerDependenciesMeta": {
    "zod": {
      "optional": false
    }
  },
  "devDependencies": {
    "ai": "^7.0.18",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^4.1.10",
    "zod": "^4.4.3"
  },
  "bugs": {
    "url": "https://github.com/kakunin-ai/kakunin-integrations/issues"
  }
}
